@namespace ShiftSoftware.ShiftBlazor.Components
@using MudBlazor
@typeparam T

@*
    Renders a collection as a single line of chips. At most MaxVisible chips are rendered; the rest
    collapse into a trailing "+N" chip that opens a popup listing the full set. The cutoff is
    deterministic (always the first MaxVisible items) — chips are NOT measured against the available
    width, so there is no JS, no ResizeObserver, and no per-render layout work. When the visible
    chips don't fit a width-constrained host, they shrink and ellipsize their labels via CSS —
    every rendered chip stays visible; nothing is silently clipped.

    MaxVisible="0" renders count-only mode: a single count chip that opens the popup, for data
    where most rows have more chips than any sensible inline threshold.

        <ShiftChipDisplay Items="row.Tags">
            <ChipTemplate Context="tag"><MudChip T="string">@tag.Name</MudChip></ChipTemplate>
        </ShiftChipDisplay>
*@

@if (_items.Count > 0)
{
    var maxVisible = Math.Max(0, MaxVisible);
    <div class="shift-chip-display">
        @if (maxVisible == 0)
        {
            @* Count-only mode: one chip with the total that opens the full list. For data where most
               rows exceed any inline threshold, inline chips cost space and the click is needed
               anyway — a single count button is clearer and cheaper. *@
            <span class="shift-chip-display__overflow" @onclick:stopPropagation="true">
                <MudChip T="string" Size="@Size" Icon="@CountModeIcon" Class="shift-chip-display__more-chip" OnClick="@ShowAllAsync">@_items.Count</MudChip>
            </span>
        }
        else
        {
            @foreach (var item in _items.Take(maxVisible))
            {
                <span class="shift-chip-display__item">@ChipTemplate(item)</span>
            }
            @if (_items.Count > maxVisible)
            {
                <span class="shift-chip-display__overflow" @onclick:stopPropagation="true">
                    <MudChip T="string" Size="@Size" Class="shift-chip-display__more-chip" OnClick="@ShowAllAsync">+@(_items.Count - maxVisible)</MudChip>
                </span>
            }
        }
    </div>
}

@code {
    [Inject] private IDialogService DialogService { get; set; } = default!;

    /// <summary>The items to render as chips. Renders nothing when null or empty.</summary>
    [Parameter] public IEnumerable<T>? Items { get; set; }

    /// <summary>Template for a single chip; receives one item. Used both inline and in the overflow popup.</summary>
    [Parameter, EditorRequired] public RenderFragment<T> ChipTemplate { get; set; } = default!;

    /// <summary>
    /// How many chips to render before the rest collapse into the "+N" chip. Defaults to 3.
    /// 0 (or negative) switches to count-only mode: no inline chips, just a single chip showing the
    /// total that opens the popup — the right choice when most rows exceed any inline threshold,
    /// so the popup click is needed anyway.
    /// </summary>
    [Parameter] public int MaxVisible { get; set; } = 3;

    /// <summary>Optional icon for the count chip in count-only mode (MaxVisible = 0).</summary>
    [Parameter] public string? CountModeIcon { get; set; }

    /// <summary>Size of the trailing "+N" chip. Defaults to <see cref="Size.Small"/>.</summary>
    [Parameter] public Size Size { get; set; } = Size.Small;

    /// <summary>Optional title for the popup shown when the "+N" chip is clicked.</summary>
    [Parameter] public string? Title { get; set; }

    private List<T> _items = new();

    protected override void OnParametersSet()
        => _items = Items as List<T> ?? Items?.ToList() ?? new();

    // The full chip set, rendered on demand into the click-opened popup.
    private RenderFragment ChipsFragment => builder =>
    {
        var seq = 0;
        foreach (var item in _items)
            builder.AddContent(seq++, ChipTemplate(item));
    };

    private async Task ShowAllAsync()
    {
        var parameters = new DialogParameters<ShiftChipDialog>
        {
            { x => x.Content, ChipsFragment }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraSmall,
            NoHeader = string.IsNullOrEmpty(Title),
            CloseButton = false,
            BackdropClick = true,     // click outside to close
            CloseOnEscapeKey = true
        };
        await DialogService.ShowAsync<ShiftChipDialog>(Title ?? string.Empty, parameters, options);
    }
}
