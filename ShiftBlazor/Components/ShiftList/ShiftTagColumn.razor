@namespace ShiftSoftware.ShiftBlazor.Components
@using MudBlazor
@using ShiftSoftware.ShiftEntity.Model.Dtos
@using ShiftSoftware.ShiftEntity.Model.Dtos.Tagging
@typeparam T where T : ShiftEntityDTOBase, IShiftEntityTaggableDTO, new()
@inherits TemplateColumn<T>

@*
    Drop this inside a <ShiftList> wherever you want the tags column to appear:

        <ShiftList T="ProductListDTO" EntitySet="Product">
            <PropertyColumn Property="x => x.Name" />
            <ShiftTagColumn />
        </ShiftList>

    It reads the row's Tags (the DTO implements IShiftEntityTaggableDTO) and renders read-only
    chips via ShiftTagDisplay. Not using it is fine — render tags yourself with a TemplateColumn
    + <ShiftTagDisplay> (or anything else).
*@

@{
    base.BuildRenderTree(__builder);
}

@code {
    /// <summary>Chip size. Defaults to <see cref="Size.Small"/>.</summary>
    [Parameter] public Size Size { get; set; } = Size.Small;

    /// <summary>
    /// Maximum width the tags cell may grow to. Any valid CSS length. Defaults to "320px".
    /// </summary>
    [Parameter] public string CellMaxWidth { get; set; } = "320px";

    /// <summary>
    /// How many tag chips to render before the rest collapse into a "+N" overflow chip. Defaults to 3.
    /// </summary>
    [Parameter] public int MaxVisible { get; set; } = 3;

    protected override void OnParametersSet()
    {
        Title ??= "Tags";
        Sortable ??= false;
        Filterable ??= false;

        // Bound the cell width so the chips collapse into a "+N" overflow chip instead of widening the column.
        if (CellStyle?.Contains("max-width") != true)
        {
            var bound = $"max-width: {CellMaxWidth}; overflow: hidden;";
            CellStyle = string.IsNullOrWhiteSpace(CellStyle) ? bound : $"{CellStyle}; {bound}";
        }

        base.CellTemplate ??= context =>
            @<ShiftChipDisplay T="TagDTO" Items="@((context.Item as IShiftEntityTaggableDTO)?.Tags)" Size="@Size" MaxVisible="@MaxVisible">
                <ChipTemplate Context="tag">
                    @* Native title (browser tooltip) rather than MudTooltip: a Blazor component per chip
                       per row is a heavy cost on large lists. *@
                    <MudChip @key="tag" T="string" Size="@Size" Style="@ChipStyle(tag.Color)" Value="@tag.Name" title="@(string.IsNullOrWhiteSpace(tag.Description) ? null : tag.Description)" />
                </ChipTemplate>
            </ShiftChipDisplay>;

        base.OnParametersSet();
    }

    private static string ChipStyle(string? color)
        => string.IsNullOrWhiteSpace(color)
            ? string.Empty
            : $"background-color: {color}; color: white;";
}
