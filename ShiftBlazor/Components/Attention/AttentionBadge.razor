@namespace ShiftSoftware.ShiftBlazor.Components

@if (Severity is not null)
{
    <MudTooltip Text="@Tooltip" Placement="Placement.Top">
        <MudChip T="string"
                 Size="@Size"
                 Color="@ColorFor(Severity.Value)"
                 Variant="Variant.Filled"
                 Icon="@IconFor(Severity.Value)"
                 Style="cursor: default;">
            @if (ShowLabel)
            {
                @LabelFor(Severity.Value)
                @if (Count > 1)
                {
                    <MudText Typo="Typo.caption" Class="ml-1">(@Count)</MudText>
                }
            }
            else if (Count > 1)
            {
                @Count
            }
        </MudChip>
    </MudTooltip>
}

@code {
    [Parameter] public AttentionSeverity? Severity { get; set; }
    [Parameter] public int Count { get; set; } = 1;
    [Parameter] public bool ShowLabel { get; set; } = true;
    [Parameter] public Size Size { get; set; } = Size.Small;
    [Parameter] public string? Tooltip { get; set; }

    internal static Color ColorFor(AttentionSeverity s) => s switch
    {
        AttentionSeverity.Critical => Color.Error,
        AttentionSeverity.Warning => Color.Warning,
        _ => Color.Info,
    };

    internal static string IconFor(AttentionSeverity s) => s switch
    {
        AttentionSeverity.Critical => Icons.Material.Filled.Error,
        AttentionSeverity.Warning => Icons.Material.Filled.Warning,
        _ => Icons.Material.Filled.Info,
    };

    internal static string LabelFor(AttentionSeverity s) => s switch
    {
        AttentionSeverity.Critical => "Critical",
        AttentionSeverity.Warning => "Warning",
        _ => "Info",
    };
}
