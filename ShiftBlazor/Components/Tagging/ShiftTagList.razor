@namespace ShiftSoftware.ShiftBlazor.Components
@using Microsoft.Extensions.Options
@using ShiftSoftware.ShiftBlazor.Tagging
@using ShiftSoftware.ShiftEntity.Model.Dtos.Tagging

@*
    Tag vocabulary management list — a component, not a routed page. Host it in your own page:

        @page "/tags"
        @attribute [Authorize]
        <ShiftTagList />

    Row click opens ShiftTagForm (as a dialog) to view/edit; the toolbar Add opens it to create.
    Configure entity set / title / permission via services.AddShiftBlazorTagging(...).
*@

@inject IOptions<ShiftBlazorTaggingOptions> Options

<ShiftList EntitySet="@Opts.EntitySet"
           Endpoint="@Opts.Endpoint"
           BaseUrl="@Opts.BaseUrl"
           BaseUrlKey="@Opts.BaseUrlKey"
           Title="@Opts.ListTitle"
           T="TagListDTO"
           Dense
           ComponentType="typeof(ShiftTagForm)"
           HighlightSortedColumn
           TypeAuthAction="@Opts.TypeAuthAction"
           EnableExport>
    <ButtonColumn Property="x => x.Name" Title="Name" />
    <PropertyColumnExtended Property="x => x.Color" Title="Color">
        <CellTemplate Context="cell">
            @if (!string.IsNullOrWhiteSpace(cell.Item.Color))
            {
                <span style="@($"display:inline-block;width:14px;height:14px;border-radius:3px;background-color:{cell.Item.Color};vertical-align:middle;")"></span>
                <span class="ms-2">@cell.Item.Color</span>
            }
        </CellTemplate>
    </PropertyColumnExtended>
    <PropertyColumn Property="x => x.IntegrationID" Title="Integration ID" Hidden />
</ShiftList>

@code {
    private ShiftBlazorTaggingOptions Opts => Options.Value;
}
