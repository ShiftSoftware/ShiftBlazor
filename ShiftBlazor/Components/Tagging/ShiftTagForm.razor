@namespace ShiftSoftware.ShiftBlazor.Components
@using Microsoft.Extensions.Options
@using MudBlazor
@using ShiftSoftware.ShiftBlazor.Tagging
@using ShiftSoftware.ShiftEntity.Model.Dtos.Tagging

@*
    Tag create/edit form — a component, not a routed page. Host it in your own page:

        @page "/tags/{Key?}"
        <ShiftTagForm Key="@Key" />
        @code { [Parameter] public string? Key { get; set; } }

    It is also opened as a dialog automatically — by ShiftTagList's row click and by
    ShiftTagPicker's "+" add button (which default their form component to this one).
    Configure endpoint/title/permission via services.AddShiftBlazorTagging(...).
*@

@inject IOptions<ShiftBlazorTaggingOptions> Options

<ShiftEntityForm T="TagDTO"
                 Endpoint="@(Opts.Endpoint ?? Opts.EntitySet)"
                 BaseUrl="@Opts.BaseUrl"
                 BaseUrlKey="@Opts.BaseUrlKey"
                 Title="@Opts.FormTitle"
                 @bind-Value="TagItem"
                 TypeAuthAction="@Opts.TypeAuthAction"
                 @bind-Key="@Key">
    <MudTextField @bind-Value="context.Item.Name"
                  For="() => context.Item.Name"
                  Label="Name"
                  Required="true" />

    <MudTextField @bind-Value="context.Item.Color"
                  For="() => context.Item.Color"
                  Label="Color (hex, e.g. #FF0000)"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Palette" />

    <MudTextField @bind-Value="context.Item.Description"
                  For="() => context.Item.Description"
                  Label="Description"
                  Lines="2" />

    <MudTextField @bind-Value="context.Item.IntegrationID"
                  For="() => context.Item.IntegrationID"
                  Label="Integration ID"
                  HelperText="Optional external-system identifier. Must be unique if set." />
</ShiftEntityForm>

@code {
    [Parameter] public object? Key { get; set; }

    /// <summary>
    /// Pre-fills the tag name when the form is opened to create a new tag — e.g. from
    /// <c>ShiftTagPicker</c>'s QuickAdd "+" button, which passes the text the user typed.
    /// Ignored when editing an existing tag (the loaded entity wins).
    /// </summary>
    [Parameter] public string? TagName { get; set; }

    private TagDTO TagItem = new();

    private ShiftBlazorTaggingOptions Opts => Options.Value;

    protected override void OnInitialized()
    {
        if (!string.IsNullOrWhiteSpace(TagName))
            TagItem.Name = TagName;
    }
}
