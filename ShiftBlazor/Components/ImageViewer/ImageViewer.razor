@namespace ShiftSoftware.ShiftBlazor.Components
@implements IShortcutComponent

<MudDialog ContentClass="siv-dialog-content">
    <DialogContent>
        <div class="shift-image-viewer" tabindex="0" @ref="ViewerRef" @onkeydown="HandleKeyDown">

            @* ---------- Toolbar ---------- *@
            <div class="siv-toolbar">
                <MudIcon Icon="@Icons.Material.Filled.Collections" Size="Size.Medium" />
                <span class="siv-title">@(Title ?? Loc["GalleryDefaultTitle"])</span>

                @if (Items.Count > 1)
                {
                    <span class="siv-counter">@(currentIndex + 1) / @Items.Count</span>
                }

                <MudSpacer />

                @if (CurrentIsImage)
                {
                    <MudTooltip Text="@Loc["ImageViewerZoomOut"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                       Color="Color.Inherit"
                                       Disabled="@(scale <= MinScale)"
                                       OnClick="ZoomOut"
                                       aria-label="@Loc["ImageViewerZoomOut"]" />
                    </MudTooltip>

                    <span class="siv-zoom-label">@ZoomLabel</span>

                    <MudTooltip Text="@Loc["ImageViewerZoomIn"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                       Color="Color.Inherit"
                                       Disabled="@(scale >= MaxScale)"
                                       OnClick="ZoomIn"
                                       aria-label="@Loc["ImageViewerZoomIn"]" />
                    </MudTooltip>

                    <MudTooltip Text="@Loc["ImageViewerResetZoom"]">
                        <MudIconButton Icon="@Icons.Material.Filled.ZoomOutMap"
                                       Color="Color.Inherit"
                                       Disabled="@(!IsTransformed)"
                                       OnClick="ResetTransform"
                                       aria-label="@Loc["ImageViewerResetZoom"]" />
                    </MudTooltip>

                    <MudTooltip Text="@Loc["ImageViewerRotate"]">
                        <MudIconButton Icon="@Icons.Material.Filled.RotateRight"
                                       Color="Color.Inherit"
                                       OnClick="RotateCw"
                                       aria-label="@Loc["ImageViewerRotate"]" />
                    </MudTooltip>

                    <MudDivider Vertical Class="siv-divider" FlexItem />
                }

                @if (!string.IsNullOrWhiteSpace(CurrentUrl))
                {
                    <MudTooltip Text="@Loc["DownloadFile"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Download"
                                       Color="Color.Inherit"
                                       Href="@CurrentUrl"
                                       Target="_blank"
                                       aria-label="@Loc["DownloadFile"]" />
                    </MudTooltip>
                }

                <MudTooltip Text="@Loc["ModalClose"]">
                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                   Color="Color.Inherit"
                                   OnClick="Close"
                                   aria-label="@Loc["ModalClose"]" />
                </MudTooltip>
            </div>

            @* ---------- Stage ---------- *@
            <div class="siv-stage"
                 @onpointerdown="OnPointerDown"
                 @onpointermove="OnPointerMove"
                 @onpointerup="OnPointerUp"
                 @onpointerleave="OnPointerUp"
                 @onwheel="OnWheel"
                 @ondblclick="ToggleZoom">

                @if (!HasItems)
                {
                    <div class="siv-empty">
                        <MudIcon Icon="@Icons.Material.Filled.HideImage" Size="Size.Large" />
                        <MudText>@Loc["NoFilesSelected"]</MudText>
                    </div>
                }
                else if (Current is not null)
                {
                    @if (CurrentIsImage)
                    {
                        <img class="siv-image @(isDragging ? "siv-dragging" : null) @(IsZoomed ? "siv-zoomed" : null)"
                             src="@CurrentUrl"
                             alt="@Current.Name"
                             style="@ImageTransform"
                             draggable="false" />
                    }
                    else
                    {
                        <div class="siv-file">
                            <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" />
                            <MudText Typo="Typo.h6" Class="siv-file-name">@Current.Name</MudText>
                            @if (!string.IsNullOrWhiteSpace(CurrentUrl))
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Download"
                                           Href="@CurrentUrl"
                                           Target="_blank">
                                    @Loc["DownloadFile"]
                                </MudButton>
                            }
                        </div>
                    }
                }

                @if (Items.Count > 1)
                {
                    @* Swallow the arrows' double-click so it doesn't bubble to the stage and toggle zoom. *@
                    <span @ondblclick:stopPropagation="true">
                        <MudIconButton Class="siv-nav siv-nav-prev"
                                       Icon="@Icons.Material.Filled.ChevronLeft"
                                       Color="Color.Inherit"
                                       Size="Size.Large"
                                       OnClick="Prev"
                                       aria-label="@Loc["ImageViewerPrevious"]" />
                        <MudIconButton Class="siv-nav siv-nav-next"
                                       Icon="@Icons.Material.Filled.ChevronRight"
                                       Color="Color.Inherit"
                                       Size="Size.Large"
                                       OnClick="Next"
                                       aria-label="@Loc["ImageViewerNext"]" />
                    </span>
                }
            </div>

            @* ---------- Thumbnail strip ---------- *@
            @if (Items.Count > 1)
            {
                <div class="siv-thumbs">
                    @for (var i = 0; i < Items.Count; i++)
                    {
                        var index = i;
                        var item = Items[index];
                        <div class="siv-thumb @(index == currentIndex ? "active" : null)"
                             @key="item.Key"
                             @onclick="@(() => Select(index))">
                            @if (item.IsImage && !string.IsNullOrWhiteSpace(item.Url))
                            {
                                <img src="@item.Url" alt="@item.Name" draggable="false" />
                            }
                            else
                            {
                                <MudIcon Icon="@Icons.Material.Filled.InsertDriveFile" />
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </DialogContent>
</MudDialog>
